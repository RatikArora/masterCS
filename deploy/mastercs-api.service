[Unit]
Description=MasterCS FastAPI Backend
After=network.target mysql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/mastercs/backend
EnvironmentFile=/opt/mastercs/backend/.env
ExecStart=/opt/mastercs/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

# Logs
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
